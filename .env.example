# ── API Keys ──
FINNHUB_API_KEY=
FMP_API_KEY=
POLYGON_API_KEY=
UW_API_KEY=
QUIVER_API_KEY=

# ── Feature Flags ──
ENABLE_POLYGON=false
ENABLE_SMART_MONEY=false
ENABLE_QUIVER=false
ENABLE_INTRADAY=false
PAPER_TRADE_MODE=true

# ── Strategy Enable/Disable ──
ENABLE_STAT_ARB=true
ENABLE_CATALYST=true
ENABLE_CROSS_ASSET=true
ENABLE_FLOW=false
ENABLE_GAP_REVERSION=false

# ── Risk Parameters ──
INITIAL_CAPITAL=100000
MAX_POSITION_PCT=0.08
MAX_GROSS_EXPOSURE=2.0
MAX_DRAWDOWN_PCT=0.15
KELLY_FRACTION=0.5
TAIL_HEDGE_PCT=0.03

# ── Execution Mode ──
EXECUTION_MODE=advisory

# ── Database ──
DATABASE_URL=sqlite:///./quantpulse.db

# ── Alert Delivery ──
NTFY_TOPIC=quantpulse-alerts
NTFY_PRIORITY=high
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=trading
SENDGRID_API_KEY=
ALERT_EMAIL_TO=

# ── Alert Preferences ──
ALERT_MARKET_HOURS_ONLY=true
ALERT_THROTTLE_MINUTES=30
ALERT_MIN_SCORE_FOR_PUSH=65
